# === JARVIS BACKEND — ÖRNEK ENV (gerçek değer İÇERMEZ) ===
# Kullanım (yerel):  cp .env.example .env   sonra değerleri doldur.
# Bu dosya commit EDİLİR; .env commit EDİLMEZ (.gitignore'da).
# Railway'de bu değerler dashboard > Variables'a girilir (.env yüklenmez).

# --- Ortam ---
# Yerel: development. Railway'de: production (production'da boş/zayıf sır = başlangıç hatası).
ENVIRONMENT=development

# --- PostgreSQL (SADECE yerel geliştirme değeri) ---
# Railway: DATABASE_URL'i Postgres eklentisi OTOMATİK sağlar (postgresql://...) — elle girme.
# Kod çıplak postgresql://'i otomatik +psycopg'ye çevirir.
DATABASE_URL=postgresql+psycopg://jarvis:jarvis_local_dev@localhost:5432/jarvis

# --- Backend endpoint koruması (SPEC 7.3) ---
# Rastgele uzun değer üret:  python -c "import secrets; print(secrets.token_hex(32))"
API_SHARED_SECRET=

# --- Google Gemini (Faz 1) ---
# AI Studio API anahtarı. Places ile AYNI projeyi kullanma (billing tuzağı, SPEC).
GEMINI_API_KEY=
# Birincil model. gemini-flash-latest = Google'ın güncel en iyi flash'ini takip eden stabil alias.
GEMINI_MODEL=gemini-flash-latest
# Birincil 503/429/504 verirse sırayla denenecek yedekler (virgülle).
GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-3-flash-preview
# Thinking gecikmesi: 0 = kapalı (hızlı, Faz 1 için ideal). Faz 4'te yükseltilebilir.
GEMINI_THINKING_BUDGET=0

# --- Groq STT (Faz 2) ---
# console.groq.com API anahtarı (ücretsiz).
# Deepgram STT (Nova-3) — BİRİNCİL. console.deepgram.com → API Keys.
# Ayarlıysa Whisper yerine kullanılır (keyterm boost ile isim isabeti). Hata olursa Whisper'a düşer.
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3

# Groq Whisper (yedek STT)
GROQ_API_KEY=
GROQ_STT_MODEL=whisper-large-v3

# --- Google Cloud TTS (Faz 3) ---
# Kimlik için İKİSİNDEN BİRİ yeterli:
#  - Yerel:  GOOGLE_APPLICATION_CREDENTIALS = servis hesabı JSON dosyasının TAM YOLU
#  - Railway: GOOGLE_APPLICATION_CREDENTIALS_JSON = JSON'un TÜM içeriği (kod temp dosyaya yazar)
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_APPLICATION_CREDENTIALS_JSON=
# Ses (Chirp3-HD). 30 tr-TR sesi var, hepsi telaffuzda eşit; varsayılan: Achird (erkek).
GOOGLE_TTS_VOICE=tr-TR-Chirp3-HD-Achird
GOOGLE_TTS_LANGUAGE=tr-TR
