# === JARVIS BACKEND — ÖRNEK ENV (gerçek değer İÇERMEZ) ===
# Kullanım (yerel):  cp .env.example .env   sonra değerleri doldur.
# Bu dosya commit EDİLİR; .env commit EDİLMEZ (.gitignore'da).
# Railway'de bu değerler dashboard > Variables'a girilir (.env yüklenmez).

# --- PostgreSQL ---
# Yerel (Docker): docker-compose.yml varsayılanlarıyla eşleşir.
# Railway: DATABASE_URL'i Postgres eklentisi OTOMATİK sağlar — elle girme.
DATABASE_URL=postgresql+psycopg://jarvis:jarvis_local_dev@localhost:5432/jarvis

# --- Backend endpoint koruması (SPEC 7.3) ---
# Rastgele uzun değer üret:  python -c "import secrets; print(secrets.token_hex(32))"
API_SHARED_SECRET=

# --- Google Gemini (Faz 1) ---
# AI Studio API anahtarı. Places ile AYNI projeyi kullanma (billing tuzağı, SPEC).
GEMINI_API_KEY=
# Ücretsiz tier modelleri: gemini-2.5-flash (stabil) / gemini-3-flash (grounding+FC, Faz 4)
GEMINI_MODEL=gemini-2.5-flash
