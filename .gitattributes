# Tüm metin dosyaları repoda LF ile saklanır (Railway/Linux deploy için tutarlı).
* text=auto eol=lf

# Kabuk betikleri her zaman LF (Railway'de bash çalıştırır; CRLF bozar)
*.sh text eol=lf

# İkili dosyalar (ileriki fazlar: ses modelleri, görseller)
*.png binary
*.jpg binary
*.jpeg binary
*.zip binary
*.onnx binary
*.tflite binary
*.ppn binary
*.keystore binary
*.jks binary
